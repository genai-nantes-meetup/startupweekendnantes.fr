---
import Layout from '../../layouts/Layout.astro';
import { pastEditions } from '../../data/editions-archive';
import { buildPastEditionJsonLd } from '../../data/structured-data';
import '../../styles/global.css';

export function getStaticPaths() {
  return pastEditions.map((ed) => ({
    params: { year: ed.slug },
    props: { ed },
  }));
}

const { ed } = Astro.props;

const title = `Startup Weekend Nantes ${ed.year} — ${ed.editionNumber}ᵉ édition`;
const description = ed.recap;
const jsonLd = buildPastEditionJsonLd(ed);
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <main class="edition">
    <a href="/" class="edition-logo" aria-label="Startup Weekend Nantes">
      <img
        src="/assets/images/brand/logo-startup-weekend-nantes.png"
        alt="Startup Weekend Nantes"
        width="147"
        height="47"
      />
    </a>

    <nav class="edition-breadcrumb" aria-label="Fil d'Ariane">
      <a href="/">Accueil</a> › <a href="/editions">Éditions</a> › <span>{ed.year}</span>
    </nav>

    <div class="edition-content">
      <p class="edition-eyebrow">{ed.editionNumber}ᵉ édition · {ed.dateLabel}</p>
      <h1>Startup Weekend Nantes {ed.year}</h1>
      <p class="edition-recap">{ed.recap}</p>

      <div class="edition-videos">
        {
          ed.videos.map((video) => (
            <figure class="edition-video">
              <figcaption>{video.label}</figcaption>
              <div class="edition-video-frame">
                <iframe
                  src={video.embedUrl}
                  title={video.title}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                />
              </div>
            </figure>
          ))
        }
      </div>

      <div class="edition-actions">
        <a href="/" class="btn-primary">Voir l'édition à venir</a>
        <a href="/editions" class="edition-back">← Toutes les éditions</a>
      </div>
    </div>
  </main>
</Layout>

<style>
  .edition {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    padding: 64px 24px;
    text-align: center;
    background:
      radial-gradient(circle at 50% 0%, var(--sw-purple) 0%, transparent 60%), var(--sw-bg);
  }

  .edition-logo img {
    display: block;
    height: clamp(44px, 6vw, 60px);
    width: auto;
  }

  .edition-breadcrumb {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.55);
  }

  .edition-breadcrumb a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
  }

  .edition-breadcrumb a:hover {
    color: var(--sw-cyan);
  }

  .edition-content {
    max-width: 860px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .edition-eyebrow {
    font-size: 15px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--sw-cyan);
    margin: 0;
  }

  .edition-content h1 {
    font-size: clamp(30px, 7vw, 52px);
    margin: 0;
  }

  .edition-recap {
    font-size: 18px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.78);
    margin: 0;
    max-width: 680px;
  }

  .edition-videos {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
    width: 100%;
    margin-top: 16px;
  }

  .edition-video {
    margin: 0;
  }

  .edition-video figcaption {
    font-family: 'Helvetica Neue Heavy', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 16px;
    color: white;
    margin-bottom: 10px;
    text-align: left;
  }

  .edition-video-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
  }

  .edition-video-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .edition-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    margin-top: 24px;
  }

  .edition-back {
    color: var(--sw-cyan);
    font-weight: 600;
    text-decoration: none;
  }

  .edition-back:hover {
    text-decoration: underline;
  }

  .btn-primary {
    display: inline-block;
    padding: 18px 30px;
    background: var(--sw-blue);
    color: var(--sw-purple);
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 4px;
    box-shadow: 0 5px 0 rgb(23, 116, 156);
    transition:
      box-shadow 0.15s,
      transform 0.15s;
  }

  .btn-primary:hover {
    box-shadow: 0 3px 0 rgb(23, 116, 156);
    transform: translateY(2px);
  }
</style>
