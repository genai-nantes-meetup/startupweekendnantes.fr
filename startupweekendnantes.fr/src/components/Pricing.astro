---
const tiers = [
  {
    label: 'Réduit',
    price: '5€',
    description: 'Étudiants, demandeurs d\'emploi',
    cta: 'Je prends ma place',
    href: 'https://www.billetweb.fr/startup-weekend-nantes-2025',
    highlight: false,
    color: '#fae01b',
  },
  {
    label: 'Standard',
    price: '59,50€',
    description: 'Tarif général ouvert à tous',
    cta: 'Je prends ma place',
    href: 'https://www.billetweb.fr/startup-weekend-nantes-2025',
    highlight: true,
    color: '#2aebf5',
  },
  {
    label: 'Corporate',
    price: '500€',
    description: 'Pour les entreprises souhaitant sponsoriser',
    cta: 'Nous contacter',
    href: 'mailto:maxime.pitussi@gmail.com',
    highlight: false,
    color: '#fc233d',
  },
];
---

<section id="pricing" class="pricing-section">
  <div class="pricing-container">
    <div class="pricing-grid">
      {tiers.map((t) => (
        <div class={`pricing-card ${t.highlight ? 'pricing-card--highlight' : ''}`} style={`--card-color: ${t.color}`}>
          <div class="card-header">
            <span class="card-label">{t.label}</span>
            <span class="card-price">{t.price}</span>
          </div>
          <p class="card-desc">{t.description}</p>
          <a href={t.href} target="_blank" rel="noopener noreferrer" class="card-cta">
            {t.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing-section {
    background: rgb(14, 2, 24);
    padding: 5rem 2rem;
  }

  .pricing-container {
    max-width: 1240px;
    margin: 0 auto;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .pricing-card {
    background: var(--card-color);
    border-radius: 8px;
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-label {
    font-family: 'Oxanium', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgb(25, 5, 50);
    opacity: 0.7;
  }

  .card-price {
    font-family: 'Dela Gothic One', sans-serif;
    font-size: 2.5rem;
    color: rgb(25, 5, 50);
    line-height: 1;
  }

  .card-desc {
    font-family: 'Oxanium', sans-serif;
    font-size: 0.875rem;
    color: rgb(25, 5, 50);
    opacity: 0.8;
    margin: 0;
    flex: 1;
    line-height: 1.5;
  }

  .card-cta {
    display: block;
    text-align: center;
    padding: 0.75rem 1rem;
    background: rgb(25, 5, 50);
    color: white;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 4px;
    transition: opacity 0.2s;
  }

  .card-cta:hover {
    opacity: 0.85;
  }

  @media (max-width: 767px) {
    .pricing-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 768px) and (max-width: 1239px) {
    .pricing-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }
    .pricing-card {
      padding: 2rem 1.25rem;
    }
  }
</style>
