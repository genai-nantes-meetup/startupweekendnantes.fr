---
---
<section id="contact" class="contact-section">
  <div class="contact-container">
    <h2>Une question ? N'hésite pas à nous contacter</h2>
    <form
      class="contact-form"
      action={`mailto:maxime.pitussi@gmail.com`}
      method="GET"
    >
      <div class="form-row">
        <input type="text" name="subject" placeholder="Prénom" required class="form-input" />
        <input type="email" name="email" placeholder="Email" required class="form-input" />
      </div>
      <textarea name="body" placeholder="Message" rows="5" required class="form-textarea"></textarea>
      <button type="submit" class="form-submit">Send</button>
    </form>
  </div>
</section>

<style>
  .contact-section {
    background: rgb(14, 2, 24);
    padding: 5rem 2rem;
  }

  .contact-container {
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-container h2 {
    font-family: 'Oxanium', sans-serif;
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.7);
    font-weight: 400;
    margin: 0 0 2rem;
    line-height: 1.5;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-input,
  .form-textarea {
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 4px;
    color: white;
    font-family: 'Oxanium', sans-serif;
    font-size: 0.875rem;
    padding: 0.875rem 1rem;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    width: 100%;
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }

  .form-input:focus,
  .form-textarea:focus {
    background: rgba(255, 255, 255, 0.18);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-submit {
    display: block;
    width: 100%;
    padding: 1rem;
    background: rgb(39, 168, 224);
    color: rgb(25, 5, 50);
    font-family: 'Dela Gothic One', sans-serif;
    font-size: 1rem;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    box-shadow: 0 5px 0 rgb(23, 116, 156);
    transition: box-shadow 0.15s, transform 0.15s;
  }

  .form-submit:hover {
    box-shadow: 0 3px 0 rgb(23, 116, 156);
    transform: translateY(2px);
  }

  @media (max-width: 767px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
