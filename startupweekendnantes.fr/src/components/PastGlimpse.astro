---
---
<section id="past" class="past-section">
  <div class="past-container">
    <h2>Revivez les moments forts de l'édition 2024 !</h2>
    <div class="videos-grid">
      <div class="video-card">
        <span class="video-label">L'aftermovie</span>
        <div class="video-wrapper">
          <iframe
            src="https://www.youtube.com/embed/ol4yYOPwQF0"
            title="Aftermovie Startup Weekend Nantes 2024"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </div>
      <div class="video-card">
        <span class="video-label">Les réactions</span>
        <div class="video-wrapper">
          <iframe
            src="https://www.youtube.com/embed/ZuHqOfZbAvg"
            title="Réactions Startup Weekend Nantes 2024"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .past-section {
    background: rgb(14, 2, 24);
    padding: 5rem 2rem;
  }

  .past-container {
    max-width: 1240px;
    margin: 0 auto;
  }

  .past-container h2 {
    font-family: 'Dela Gothic One', sans-serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: white;
    margin: 0 0 3rem;
  }

  .videos-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .video-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .video-label {
    font-family: 'Oxanium', sans-serif;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 8px;
    background: #111;
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 767px) {
    .videos-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
